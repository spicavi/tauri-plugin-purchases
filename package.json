{
  "name": "@spicavi/tauri-plugin-purchases",
  "version": "0.1.1",
  "description": "In-app subscriptions and purchases for Tauri 2 apps — StoreKit 2 on iOS (Google Play Billing planned).",
  "license": "MIT",
  "author": "spicavi <avisaksham@gmail.com>",
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "exports": {
    "types": "./dist-js/index.d.ts",
    "import": "./dist-js/index.js",
    "require": "./dist-js/index.cjs"
  },
  "files": [
    "dist-js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tauri",
    "tauri-plugin",
    "storekit",
    "iap",
    "in-app-purchase",
    "subscriptions",
    "ios"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "check-types": "tsc --noEmit",
    "prepack": "pnpm build",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "@tauri-apps/api": ">=2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
